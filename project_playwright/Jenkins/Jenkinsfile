pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        choice(
            name: 'SUITE',
            choices: ['UI', 'API'],
            description: 'Choose which test suite Jenkins should run.'
        )
        choice(
            name: 'ENV',
            choices: ['qa'],
            description: 'Target environment loaded from config/env.yaml.'
        )
        booleanParam(
            name: 'HEADLESS',
            defaultValue: true,
            description: 'Run Playwright in headless mode.'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Initialize') {
            steps {
                dir('project_playwright') {
                    script {
                        env.SUITE_SLUG = params.SUITE.toLowerCase()
                        env.SUITE_PATH = params.SUITE == 'UI' ? 'tests/UI' : 'tests/API'
                        env.SUITE_MARKER = params.SUITE == 'UI' ? 'ui' : 'api'
                        env.ARTIFACT_ROOT = "ci-artifacts/${env.SUITE_SLUG}/${env.BUILD_NUMBER}"
                        env.LOGS_DIR = "${env.ARTIFACT_ROOT}/logs"
                        env.ALLURE_DIR = "${env.ARTIFACT_ROOT}/allure-results"
                        env.SCREENSHOTS_DIR = "${env.ARTIFACT_ROOT}/screenshots"
                        env.VIDEO_DIR = "${env.ARTIFACT_ROOT}/video"
                        env.DOWNLOADS_DIR = "${env.ARTIFACT_ROOT}/downloads"
                        env.RESULTS_XML = "${env.ARTIFACT_ROOT}/test-results.xml"
                        env.PYTHON_CMD = ""
                        env.PYTHON_ARGS = ""
                    }
                }
            }
        }

        stage('Resolve Python') {
            steps {
                dir('project_playwright') {
                    powershell '''
                        if (Get-Command py -ErrorAction SilentlyContinue) {
                            $env:PYTHON_CMD = "py"
                            $env:PYTHON_ARGS = "-3"
                            Write-Host "Using Python launcher: py -3"
                            exit 0
                        }

                        if (Get-Command python -ErrorAction SilentlyContinue) {
                            $env:PYTHON_CMD = "python"
                            $env:PYTHON_ARGS = ""
                            Write-Host "Using Python command: python"
                            exit 0
                        }

                        throw "Neither 'py' nor 'python' was found on the Jenkins agent. Install Python 3 and ensure it is available to the Jenkins service account."
                    '''
                }
            }
        }

        stage('Clean Suite Artifacts') {
            steps {
                dir('project_playwright') {
                    powershell '''
                        if (Test-Path $env:ARTIFACT_ROOT) {
                            Remove-Item -LiteralPath $env:ARTIFACT_ROOT -Recurse -Force
                        }

                        $workspacePaths = @(
                            "logs",
                            "allure-results",
                            "screenshots",
                            "downloads",
                            "video",
                            "test-results.xml"
                        )

                        foreach ($path in $workspacePaths) {
                            if (Test-Path $path) {
                                Remove-Item -LiteralPath $path -Recurse -Force
                            }
                        }

                        $paths = @(
                            $env:LOGS_DIR,
                            $env:ALLURE_DIR,
                            $env:SCREENSHOTS_DIR,
                            $env:VIDEO_DIR,
                            $env:DOWNLOADS_DIR
                        )

                        foreach ($path in $paths) {
                            New-Item -ItemType Directory -Force -Path $path | Out-Null
                        }
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('project_playwright') {
                    powershell '''
                        if ($env:PYTHON_ARGS) {
                            & $env:PYTHON_CMD $env:PYTHON_ARGS --version
                            & $env:PYTHON_CMD $env:PYTHON_ARGS -m pip install --upgrade pip
                            & $env:PYTHON_CMD $env:PYTHON_ARGS -m pip install -r requirements.txt
                            & $env:PYTHON_CMD $env:PYTHON_ARGS -m playwright install
                        } else {
                            & $env:PYTHON_CMD --version
                            & $env:PYTHON_CMD -m pip install --upgrade pip
                            & $env:PYTHON_CMD -m pip install -r requirements.txt
                            & $env:PYTHON_CMD -m playwright install
                        }
                    '''
                }
            }
        }

        stage('Run Suite') {
            steps {
                dir('project_playwright') {
                    powershell '''
                        $env:LOG_DIR = "logs"
                        $env:SCREENSHOT_DIR = "screenshots"

                        Write-Host "Running suite: $($env:SUITE)"
                        Write-Host "Environment: $($env:ENV)"
                        Write-Host "Headless: $($env:HEADLESS)"

                        if ($env:PYTHON_ARGS) {
                            & $env:PYTHON_CMD $env:PYTHON_ARGS -m pytest $env:SUITE_PATH -m $env:SUITE_MARKER -v --tb=short
                        } else {
                            & $env:PYTHON_CMD -m pytest $env:SUITE_PATH -m $env:SUITE_MARKER -v --tb=short
                        }
                    '''
                }
            }
        }

        stage('Collect Artifacts') {
            steps {
                dir('project_playwright') {
                    powershell '''
                        New-Item -ItemType Directory -Force -Path $env:ARTIFACT_ROOT | Out-Null
                        $artifactPaths = @(
                            @{ Source = "logs"; Target = $env:LOGS_DIR },
                            @{ Source = "allure-results"; Target = $env:ALLURE_DIR },
                            @{ Source = "screenshots"; Target = $env:SCREENSHOTS_DIR },
                            @{ Source = "video"; Target = $env:VIDEO_DIR },
                            @{ Source = "downloads"; Target = $env:DOWNLOADS_DIR }
                        )

                        foreach ($item in $artifactPaths) {
                            if (Test-Path $item.Source) {
                                Get-ChildItem -Path $item.Source -Force | Copy-Item -Destination $item.Target -Recurse -Force
                            }
                        }

                        if (Test-Path "test-results.xml") {
                            Copy-Item -Path "test-results.xml" -Destination $env:RESULTS_XML -Force
                        }
                    '''
                }
            }
        }
    }

    post {
        always {
            dir('project_playwright') {
                junit testResults: "${env.RESULTS_XML}", allowEmptyResults: true
                archiveArtifacts artifacts: "${env.ARTIFACT_ROOT}/**", allowEmptyArchive: true
            }
        }
        cleanup {
            cleanWs()
        }
    }
}
